{
  "name": "eco",
  "version": "1.0.0-alpha",
  "description": "Eco is a compiler for Elm, targetting native execution.",
  "author": "Rupert Smith",
  "license": "BSD-3-Clause",
  "main": "lib/index.js",
  "bin": {
    "guida": "bin/index.js"
  },
  "scripts": {
    "build": "npm-run-all --sequential build:*",
    "build:bin": "./scripts/build.sh bin",
    "buildself": "./scripts/build-self.sh bin",
    "watch": "onchange \"src/**/*.elm\" -- npm run build:bin",
    "test": "elm-test-rs --project build-xhr --fuzz 10",
    "elm-format": "elm-format . --yes",
    "prepare": "npm run build"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "form-data": "^4.0.2",
    "indexeddb-fs": "^2.1.5",
    "jszip": "^3.10.1",
    "mock-xmlhttprequest": "^8.4.1",
    "terser": "^5.44.1",
    "tmp": "^0.2.3",
    "which": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "elm": "^0.19.1-6",
    "elm-format": "^0.8.7",
    "elm-review": "^2.13.2",
    "elm-test": "^0.19.1-revision15",
    "elm-test-rs": "^3.0.1-0",
    "eslint": "^9.23.0",
    "eslint-plugin-jest": "^28.11.0",
    "globals": "^16.0.0",
    "guida": "^0.3.0-alpha",
    "jest": "^29.7.0",
    "npm-run-all": "^4.1.5",
    "onchange": "^7.1.0",
    "uglify-js": "^3.19.3"
  }
}
